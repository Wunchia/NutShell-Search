```cpp
void KeywordProcessor::build_en_index(const std::string& dict,
                                      const std::string& index)
{
    std::map<std::string, std::set<int>> prefixIndex;  // char → string
    std::ifstream ifs(dict);
    std::string word;
    int freq;
    int lineNo = 1;

    while (ifs >> word >> freq) {
        if (!word.empty()) {
            // 为每个前缀长度建索引: 1, 2, 3...
            for (size_t len = 1; len <= word.size(); ++len) {
                prefixIndex[word.substr(0, len)].insert(lineNo);
            }
        }
        lineNo++;
    }

    std::ofstream ofs(index);
    for (const auto& [prefix, lines] : prefixIndex) {
        ofs << prefix;
        for (int line : lines) {
            ofs << " " << line;
        }
        ofs << "\n";
    }
}
```

