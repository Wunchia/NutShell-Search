        std::cout << "[DirectoryScanner] Found " << files.size()
                  << " files in corpus/EN" << std::endl;
        for (const auto& f : files) {
            std::cout << "  " << f << std::endl;
        }
    } catch (const std::exception& e) {
        std::cerr << "Error: " << e.what() << std::endl;
        return 1;
    }

    return 0;
}
```

