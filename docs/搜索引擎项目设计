int del = prev[j] + 1;                              // 假设删 s1[i-1]
int ins = curr[j - 1] + 1;                           // 假设插 s2[j-1]
int sub = prev[j - 1] + (s1[i-1] == s2[j-1] ? 0 : 1); // 假设替换
