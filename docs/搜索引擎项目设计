while (ifs >> word >> freq) {
    if (word.empty()) continue;
    for (size_t len = 1; len <= word.size(); ++len) {
        rawIndex[word.substr(0, len)].insert(lineNo);
    }
    lineNo++;
}

// 第二遍：去冗 —— 只保留行号集发生变化的前缀
std::string lastKept;
for (auto& [pref, lines] : rawIndex) {
    if (pref.size() == 1) {
        compactIndex[pref] = std::move(lines);
        lastKept = pref;
        continue;
    }
    if (compactIndex[lastKept] != lines) {
        compactIndex[pref] = std::move(lines);
        lastKept = pref;
    }
}
```

