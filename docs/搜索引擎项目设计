## 实现

改 `build_en_index`，在写入 `charIndex` 之后、写文件之前加一段去冗：

```cpp
void KeywordProcessor::build_en_index(const std::string& dict,
                                      const std::string& index)
{
    std::map<std::string, std::set<int>> prefixIndex;
    std::ifstream ifs(dict);
    std::string word;
    int freq;
    int lineNo = 1;

    while (ifs >> word >> freq) {
        if (word.empty()) continue;
        for (size_t len = 1; len <= word.size(); ++len) {
            prefixIndex[word.substr(0, len)].insert(lineNo);
        }
        lineNo++;
    }

    // 去冗：删除与前一个较短前缀行号集合相同的条目
    // 按长度分组处理：同一前缀族中，保留行号集合首次缩小的那个
    std::map<std::string, std::set<int>> compactIndex;

    for (auto& [prefix, lines] : prefixIndex) {
        // 长度为1的一定保留
        if (prefix.size() == 1) {
            compactIndex[prefix] = std::move(lines);
            continue;
        }

        // 取去掉最后一个字符的前缀
        std::string shorter = prefix.substr(0, prefix.size() - 1);
        auto it = compactIndex.find(shorter);
        if (it == compactIndex.end() || it->second != lines) {
            compactIndex[prefix] = std::move(lines);
        }
    }

    std::ofstream ofs(index);
    for (const auto& [prefix, lines] : compactIndex) {
        ofs << prefix;
        for (int line : lines) {
            ofs << " " << line;
        }
        ofs << "\n";
    }

    std::cout << "[Keyword] English index keys: " << compactIndex.size()
              << std::endl;
}
```

