// TLV 协议消息体
// ============================================================
// 注意：这里没有 length 字段，因为 value.size() 就是长度
// length 只在编解码时作为临时变量使用
struct Message {
    uint8_t type;       // 1=关键字推荐, 2=网页搜索
                        // （对应 PDF 中 Message 的 type 字段）
    std::string value;  // JSON 负载
