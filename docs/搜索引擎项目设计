   150	void PageProcessor::build_inverted_index(const std::string&filename)
   151	{
   152	    int N=static_cast<int>(_documents.size());
   153
   154	    // 第一遍：统计每篇文档的词频和文档频率
   155	    std::map<int,std::map<std::string,int>> docTermCount; //docId -> (word->count)
   156	    std::map<int,int> docTotalWords;                      //docId -> 总词数
   157	    std::map<std::string,int> documentFrequency;          //word -> DF
   158
   159	    for(const auto& doc:_documents){
   160	        std::vector<std::string> words;
   161	        _tokenizer.Cut(doc.content,words);
   162
   163	        std::map<std::string,int> localFreq;
   164	        for(const auto& w:words){
   165	            if(_stopWords.count(w)>0){continue;}
   166	            if(TextUtils::is_chinese_punctuation_or_space(w)){continue;}
   167	            localFreq[w]++;
   168	        }
   169
   170	        docTermCount[doc.id]=localFreq;
   171	        docTotalWords[doc.id]=0;
   172	        for(const auto& [word,cnt]:localFreq){
   173	            docTotalWords[doc.id]+=cnt;
   174	            documentFrequency[word]++;
   175	        }
   176	    }
   177
   178	    // 第二遍：计算 TF-IDF 权重并归一化
   179	    _invertedIndex.clear();
   180
   181	    for(const auto& doc : _documents){
   182	        int totalWords=docTotalWords[doc.id];
   183	        if(totalWords==0){continue;}
   184
   185	        const auto& localFreq=docTermCount[doc.id];
   186
   187	        // 先算原始权重
   188	        std::map<std::string,double> rawWeights;
   189	        double squareSum=0.0;
   190
   191	        for(const auto& [word,cnt]:localFreq){
   192	            double tf=static_cast<double>(cnt)/totalWords;
   193	            double idf=std::log2(static_cast<double>(N)/(documentFrequency[word]+1));
   194	            double weight=tf*idf;
   195	            rawWeights[word]=weight;
   196	            squareSum+=weight*weight;
   197	        }
   198
   199	        // 归一化
   200	        double norm=std::sqrt(squareSum);
   201	        for(const auto& [word,weight]:rawWeights){
   202	            double normalized=(norm>0)?weight/norm:0.0;
   203	            _invertedIndex[word][doc.id]=normalized;
   204	        }
   205	    }
   206
   207	    // 写入倒排索引文件
   208	    std::ofstream ofs(filename);
   209	    for(const auto& [word,docMap]:_invertedIndex){
   210	        ofs<<word;
   211	        for(const auto& [docId,weight]:docMap){
   212	            ofs<<" "<<docId<<" "<<weight;
   213	        }
   214	        ofs<<"\n";
   215	    }
