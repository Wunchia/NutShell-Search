//   先读头 → 知道 value 多长 → 等到够长再取 → 不够就 break 等下次数据
//
// 使用方式：
//   TlvCodec codec([](conn, msg, time) {
//       // 收到一条完整消息，msg.type 决定走关键字推荐还是网页搜索
//   });
//   server.setMessageCallback(
