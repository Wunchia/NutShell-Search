## A3：DirectoryScanner 实现

需要改 3 个文件：

### 1. `include/common/DirectoryScanner.h`

```cpp
#pragma once

#include <string>
#include <vector>

class DirectoryScanner
{
public:
    /// 遍历目录 dir，返回目录内所有文件的完整路径（已排序）
    static std::vector<std::string> scan(const std::string& dir);

private:
    DirectoryScanner() = delete;
};
```

### 2. `src/common/DirectoryScanner.cpp`

```cpp
#include "common/DirectoryScanner.h"

#include <dirent.h>
#include <algorithm>
#include <stdexcept>

std::vector<std::string> DirectoryScanner::scan(const std::string& dir)
{
    std::vector<std::string> files;
    DIR* dp = opendir(dir.c_str());
    if (!dp) {
        throw std::runtime_error("opendir failed: " + dir);
    }

    while (dirent* entry = readdir(dp)) {
        std::string name = entry->d_name;
        if (name == "." || name == "..") {
            continue;
        }
        files.push_back(dir + "/" + name);
    }

    closedir(dp);
    std::sort(files.begin(), files.end());
    return files;
}
```

### 3. `src/offline/offline_main.cpp`

```cpp
#include "common/DirectoryScanner.h"

#include <iostream>

