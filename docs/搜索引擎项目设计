### 在 `src/online/KeywordService.cpp` 加实现

```cpp
// ============================================================
// 编辑距离（Levenshtein Distance）
// ============================================================
//
// DP 定义：
//   dp[i][j] = s1[0..i-1] 变成 s2[0..j-1] 的最小编辑距离
//
// 状态转移：
//   dp[i][j] = min(
//       dp[i-1][j]   + 1,              // 删除 s1[i-1]
//       dp[i][j-1]   + 1,              // 插入 s2[j-1]
//       dp[i-1][j-1] + (s1[i-1] == s2[j-1] ? 0 : 1)  // 替换/相等
//   )
//
// 空间优化：dp[i][*] 只依赖 dp[i-1][*]，只需保留两行。
//          用 prev 存上一行，curr 存当前行，每次迭代交换。
//
// 对中文同样适用：std::string 按字节比较，一个汉字 3 字节，
// 增删改的最小单元是 1 字节，但效果等价于按字符比较
// （因为 UTF-8 的汉字不会部分相等：中≠国，不存在"前面的字节一样"的情况）。

int KeywordService::editDistance(const std::string& s1,
                                 const std::string& s2)
{
    // 用 int 而非 size_t，因为 DP 涉及 -1 索引和比较
    int m = static_cast<int>(s1.size());
    int n = static_cast<int>(s2.size());

    // prev 存上行，curr 存当前行
    std::vector<int> prev(n + 1);
    std::vector<int> curr(n + 1);

    // 初始化第一行：空串 → s2，全是插入操作
    // prev[j] = s1 为空时，把 s2[0..j-1] 全插入的距离
    for (int j = 0; j <= n; ++j) {
        prev[j] = j;
    }

    // 逐行填充
    for (int i = 1; i <= m; ++i) {
        // curr[0] = s2 为空时，把 s1[0..i-1] 全删除的距离
        curr[0] = i;

        for (int j = 1; j <= n; ++j) {
            // 删除：删 s1[i-1]，距离 = 上行同列 + 1
            int del = prev[j] + 1;
            // 插入：插 s2[j-1]，距离 = 左格 + 1
            int ins = curr[j - 1] + 1;
            // 替换：s1[i-1]==s2[j-1] 则距离不变，否则 +1
            int sub = prev[j - 1] + (s1[i - 1] == s2[j - 1] ? 0 : 1);

            // 取三种操作的最小值
            curr[j] = std::min({del, ins, sub});
        }

        // 滚动：当前行变上行，准备下一轮
        std::swap(prev, curr);
    }

    // 最终结果在 prev[m] —— 因为最后一次迭代后交换了
    return prev[n];
}
```

