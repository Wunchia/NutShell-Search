### 完整 `query()` 实现：

```cpp
// ============================================================
// 语言检测：是否包含汉字
// ============================================================
// 遍历每个 UTF-8 字符，检查码点是否在 CJK 统一表意文字范围内
// (U+4E00 - U+9FFF)
//
bool KeywordService::containsCJK(const std::string& s)
{
    auto chars = TextUtils::split_utf8_characters(s);
    for (const auto& ch : chars) {
        // ch 是 3 字节 UTF-8 编码的汉字，我们需要它的码点
        // utf8::iterator 可以拿到码点，但这里用更简单的方式：
        // 中文 UTF-8 第一个字节范围是 0xE4-0xE9（CJK 统一汉字区）
        unsigned char firstByte = static_cast<unsigned char>(ch[0]);
        if (firstByte >= 0xE4 && firstByte <= 0xE9) {
            return true;
        }
    }
    return false;
}

// ============================================================
// query — 关键字推荐主逻辑
// ============================================================
//
// 流程：
//   1. 语言检测 → 选 dict + index
//   2. 拆关键字为字符/前缀
//   3. 查索引取行号集合 → 合并
//   4. 按行号从词典取词 → 候选列表
//   5. 每个候选词算编辑距离
//   6. 排序（编辑距离 > 词频 > 字典序）
//   7. 取 Top K → JSON 数组
//
std::string KeywordService::query(const std::string& keyword, int topK)
{
    // ----------------------------------------------------------
    // ① 语言检测：选中文还是英文
    // ----------------------------------------------------------
    bool isCN = containsCJK(keyword);
    const auto& dict = isCN ? dictCn_ : dictEn_;
    const auto& idx  = isCN ? idxCn_  : idxEn_;

    // ----------------------------------------------------------
    // ② 拆关键字
    // ----------------------------------------------------------
    // 中文：拆成单个汉字 → ["花","生"]
    // 英文：直接用整个 prefix → ["co"]（查前缀索引）
    std::vector<std::string> keys;
    if (isCN) {
        keys = TextUtils::split_utf8_characters(keyword);
    } else {
        keys.push_back(keyword);
    }

    // ----------------------------------------------------------
    // ③ 查索引 → 合并所有行号
    // ----------------------------------------------------------
    // idx_ 是 map<string, set<int>>，key 可能在索引中存在也可能不存在
    //
    // 示例：
    //   idxCn["花"] = {45, 230, ...}
    //   idxCn["生"] = {230, 401, ...}
    //   → lineNos = {45, 230, 401, ...}  （set 自动去重）
    //
    // 如果查不到（比如 "xyz" 不在英文前缀索引中），lineNos 为空，
    // 最终返回空 JSON 数组。
    std::set<int> lineNos;
    for (const auto& k : keys) {
        auto it = idx.find(k);
        if (it != idx.end()) {
            lineNos.insert(it->second.begin(), it->second.end());
        }
    }

    // ----------------------------------------------------------
    // ④ 从词典取候选词
    // ----------------------------------------------------------
    // dict 是 vector<pair<string,int>>，下标 = lineNo - 1（行号 1-based）
    //
    // 每个候选词存：{word, freq, editDist}
    // 后面排序用到全部三个字段。
    struct Candidate {
        std::string word;
        int freq;        // 词频（来自词典）
        int dist;        // 与输入关键字的编辑距离

        // 排序规则（全升序，越小越好）：
        //   ① 编辑距离小 → 越相关
        //   ② 词频高     → 越常见
        //   ③ 字典序小   → 稳定排序
        bool operator<(const Candidate& other) const {
            if (dist != other.dist) return dist < other.dist;
            if (freq != other.freq) return freq > other.freq;  // 降序：频率越大越靠前
            return word < other.word;                           // 升序：字典序越小越靠前
        }
    };

    std::vector<Candidate> candidates;
    for (int lineNo : lineNos) {
        // 行号从 1 开始，vector 下标从 0 开始
        int index = lineNo - 1;
        // 防御：行号不应超出词典范围（正常情况不会，但安全第一）
        if (index < 0 || static_cast<size_t>(index) >= dict.size()) {
            continue;
        }

        const auto& [word, freq] = dict[index];
        int dist = editDistance(keyword, word);

        // 编辑距离小于等于关键字长度才可能相关
        // 比如搜 "花"（3字节），候选 "社会主义"（12字节）距离至少 9，
        // 这种候选词放到列表里毫无意义，提前过滤。
        // 阈值设为 max(keyword.size(), candidate.size()) 更合理，
        // 但为了简单：距离 <= 关键字长度 2 倍的都保留
        if (dist <= static_cast<int>(keyword.size()) * 2) {
            candidates.push_back({word, freq, dist});
        }
    }

    // ----------------------------------------------------------
    // ⑤ 排序
    // ----------------------------------------------------------
    // Candidate::operator< 已实现三级排序规则，直接 sort
    std::sort(candidates.begin(), candidates.end());

    // ----------------------------------------------------------
    // ⑥ 取 Top K → JSON
    // ----------------------------------------------------------
    nlohmann::json jsonResult = nlohmann::json::array();
    int count = 0;
    for (const auto& c : candidates) {
        if (count >= topK) break;
        jsonResult.push_back(c.word);
        ++count;
    }

    return jsonResult.dump();  // dump() 返回 JSON 字符串
}
```

